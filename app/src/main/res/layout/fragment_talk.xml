<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".fragments.TalkFragment"
    android:id="@+id/TalkFragment"
    android:background="@color/mainpink">

    <TextView
        android:id="@+id/talksay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:text="안녕"
        android:textColor="@color/white2"
        android:textStyle="bold"
        android:fontFamily="@font/binggrre"
        android:textSize="25sp"
        />

    <ImageButton
        android:id="@+id/sayhellobutton"
        android:layout_width="55dp"
        android:layout_height="25dp"
        android:layout_marginLeft="250dp"
        android:layout_alignBottom="@id/talksay"
        android:src="@drawable/ic_baseline_keyboard_arrow_down_24"/>



</RelativeLayout>