<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".WriteDiary"
    android:padding="35dp"
    android:background="@color/mainpink"
    android:id="@+id/writediaryFragment">


    <!-- TODO: Update blank fragment layout -->
    <EditText
        android:autofillHints="..."
        android:inputType="text"
        android:id="@+id/EditDiaryContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:fontFamily="@font/binggrre"
        android:textSize="24sp"
        android:background="@color/white2"
        />
    <Button
        android:id="@+id/btnDiarySend"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/EditDiaryContent"
        app:layout_constraintRight_toRightOf="@id/EditDiaryContent"
        android:text="제출"/>

</androidx.constraintlayout.widget.ConstraintLayout>